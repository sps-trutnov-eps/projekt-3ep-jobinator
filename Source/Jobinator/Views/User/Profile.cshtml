@model Jobinator.Models.User

@{
    ViewData["Title"] = "Profile";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <h2 class="card-title text-primary mb-2">@Model.Name @Model.Surname</h2>
                    <h4 class="card-subtitle text-muted mb-3">@@@Model.Username</h4>
                    <p class="text-secondary px-md-5">Welcome to your profile page! Here, you can manage your personal information and track your active job postings.</p>

                    <div class="d-grid d-md-block gap-2 mt-4">
                        <button type="button" class="btn btn-primary px-4" data-bs-toggle="modal" data-bs-target="#popupFormModal">
                            <i class="bi bi-plus-lg"></i> Create New Post
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Structure -->
<div class="modal fade" id="popupFormModal" tabindex="-1" aria-labelledby="popupFormModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="popupFormModalLabel">Create a New Post</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Form Starts Here -->
                <form id="popupForm" asp-controller="Post" asp-action="Create" method="post">
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <input type="text" class="form-control" id="title" name="Title" required>
                    </div>
                    <div class="mb-3">
                        <label for="content" class="form-label">Content</label>
                        <textarea class="form-control" id="content" name="Content" rows="3" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="offerRequest" class="form-label">Select Offer/Request</label>
                        <select class="form-select" id="offerRequest" name="Type" required>
                            <option selected disabled value="">Choose...</option>
                            @foreach (var item in Enum.GetValues(typeof(Jobinator.Models.Post.PostType)))
                            {
                                <option value="@item">@item</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="category" class="form-label">Select Category</label>
                        <select class="form-select" id="category" name="Category" required>
                            <option selected disabled value="">Choose...</option>
                            @foreach (var item in Enum.GetValues(typeof(Jobinator.Models.Post.JobCategory)))
                            {
                                <option value="@item">@item</option>
                            }
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="submit" form="popupForm" class="btn btn-primary">Submit</button>
            </div>
        </div>
    </div>
</div>

<!-- Posts Section -->
<div class="container mt-5">
    <div class="d-flex align-items-center mb-4">
        <h3 class="mb-0">Your Posts</h3>
        <span class="badge bg-secondary ms-3">@(Model.Posts?.Count ?? 0)</span>
    </div>

    @if (Model.Posts != null && Model.Posts.Any())
    {
        <div class="row g-4">
            @foreach (var post in Model.Posts)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100 shadow-sm border-0 post-card">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title text-truncate mb-0">@post.Title</h5>
                                <span class="badge @(post.Type == Jobinator.Models.Post.PostType.Offer ? "bg-success" : "bg-info")">
                                    @post.Type
                                </span>
                            </div>
                            <h6 class="text-muted small mb-3">
                                <i class="bi bi-tag"></i> @post.Category
                            </h6>
                            <p class="card-text text-muted flex-grow-1">
                                @(post.Content.Length > 150 ? post.Content.Substring(0, 147) + "..." : post.Content)
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-light rounded-3">
            <i class="bi bi-journal-text display-1 text-muted"></i>
            <p class="lead text-muted mt-3">No posts found. Start by creating your first offer or demand!</p>
        </div>
    }
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
