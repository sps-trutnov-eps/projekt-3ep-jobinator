@model Jobinator.Models.User

@{
    ViewData["Title"] = "Profile";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0">
        <div class="card-body text-center">
            <h2 class="card-title text-primary mb-3">@Model.Name @Model.Surname's Profile</h2>
            <h4 class="card-subtitle text-muted mb-3">@Model.Username</h4>
            <p class="text-secondary">Welcome to your profile page, @Model.Name! Here, you can view and update your profile information.</p>

            <!-- Button to trigger the modal -->
            <button type="button" class="btn btn-primary mb-4 m-auto" data-bs-toggle="modal" data-bs-target="#popupFormModal">
                Create Post
            </button>
        </div>
    </div>
</div>

<!-- Modal Structure -->
<div class="modal fade" id="popupFormModal" tabindex="-1" aria-labelledby="popupFormModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="popupFormModalLabel">Create a New Post</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Form Starts Here -->
                <form id="popupForm" asp-controller="Post" asp-action="Create" method="post">
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <input type="text" class="form-control" id="title" name="Title" required>
                    </div>
                    <div class="mb-3">
                        <label for="content" class="form-label">Content</label>
                        <textarea class="form-control" id="content" name="Content" rows="3" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="offerRequest" class="form-label">Select Offer/Request</label>
                        <select class="form-select" id="offerRequest" name="Type" required>
                            <option selected disabled value="">Choose...</option>
                            @foreach (var item in Enum.GetValues(typeof(Jobinator.Models.Post.PostType)))
                            {
                                <option value="@item">@item</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="category" class="form-label">Select Category</label>
                        <select class="form-select" id="category" name="Category" required>
                            <option selected disabled value="">Choose...</option>
                            @foreach (var item in Enum.GetValues(typeof(Jobinator.Models.Post.JobCategory)))
                            {
                                <option value="@item">@item</option>
                            }
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="submit" form="popupForm" class="btn btn-primary">Submit</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<!-- Posts Section -->
<h3 class="mt-4">Your Posts</h3>
@if (Model.Posts != null && Model.Posts.Any())
{
    <div class="row">
        @foreach (var post in Model.Posts)
        {
            <div class="col-md-4">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">@post.Title</h5>
                        <p class="card-text">@post.Content</p>
                        <p><strong>Type:</strong> @post.Type.ToString()</p>
                        <p><strong>Category:</strong> @post.Category.ToString()</p>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p>No posts found.</p>
}
