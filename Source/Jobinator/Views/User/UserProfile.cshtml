@model Jobinator.Models.User

@{
    ViewData["Title"] = "Profile";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0">
        <div class="card-body text-center">
            <h2 class="card-title text-primary mb-3">@Model.Name @Model.Surname's Profile</h2>
            <h4 class="card-subtitle text-muted mb-3">@Model.Username</h4>
            <p class="text-secondary">Welcome to @Model.Name's profile page! Here, you can view @Model.Name's posts.</p>
            <form asp-action="LikeProfile" asp-route-username="@Model.Username" method="post">
                <button type="submit" class="btn btn-primary mb-3">
                    Like @Model.Username's Profile
                </button>
            </form>
            <p class="text-muted">
                <strong>@Model.Username</strong> has <span class="badge bg-secondary">@ViewBag.LikesCount</span> likes
            </p>
        </div>
    </div>
</div>


<!-- Display User's Posts -->
<h3 class="mt-4">@Model.Username's Posts</h3>

@if (Model.Posts != null && Model.Posts.Any())
{
    <div class="row">
        @foreach (var post in Model.Posts)
        {
            <div class="col-md-4">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">@post.Title</h5>
                        <p class="card-text">@post.Content</p>
                        <p><strong>Type:</strong> @post.Type.ToString()</p>
                        <p><strong>Category:</strong> @post.Category.ToString()</p>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p>No posts found.</p>
}